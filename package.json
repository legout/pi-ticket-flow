{
  "name": "pi-ticket-flow",
  "version": "0.3.0",
  "description": "Standalone pi package for tk ticket workflows with brainstorming, planning, ExecPlan creation, and delegated single-ticket and queue modes.",
  "keywords": [
    "pi-package",
    "pi",
    "subagents",
    "ticket-workflow",
    "execplan",
    "brainstorming",
    "planning",
    "tk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legout/pi-ticket-flow.git"
  },
  "homepage": "https://github.com/legout/pi-ticket-flow#readme",
  "bugs": {
    "url": "https://github.com/legout/pi-ticket-flow/issues"
  },
  "type": "module",
  "files": [
    "extensions",
    "prompts",
    "skills",
    "agents",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "pi-interactive-subagents": "github:HazAT/pi-interactive-subagents",
    "pi-prompt-template-model": "^0.6.8"
  },
  "bundledDependencies": [
    "pi-interactive-subagents",
    "pi-prompt-template-model"
  ],
  "bundleDependencies": [
    "pi-interactive-subagents",
    "pi-prompt-template-model"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/register-ticket-agents.ts",
      "./extensions/interactive-subagents-tools.ts",
      "./extensions/interactive-session-artifacts.ts",
      "./extensions/prompt-template-interactive-bridge.ts",
      "./node_modules/pi-prompt-template-model/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}
