{
  "name": "pi-ticket-flow",
  "version": "0.6.0",
  "description": "Standalone pi package for tk ticket workflows with brainstorming, planning, ExecPlan creation, and delegated single-ticket and queue modes.",
  "keywords": [
    "pi-package",
    "pi",
    "subagents",
    "ticket-workflow",
    "execplan",
    "brainstorming",
    "planning",
    "tk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legout/pi-ticket-flow.git"
  },
  "homepage": "https://github.com/legout/pi-ticket-flow#readme",
  "bugs": {
    "url": "https://github.com/legout/pi-ticket-flow/issues"
  },
  "type": "module",
  "scripts": {
    "smoke:delegated-outcome": "node --experimental-strip-types scripts/smoke-delegated-subagent-outcome.ts",
    "smoke:delegated-retry": "node --experimental-strip-types scripts/smoke-delegated-retry.ts",
    "smoke:delegated-policy": "node --experimental-strip-types scripts/smoke-delegated-policy.ts",
    "smoke:model-selection": "node --experimental-strip-types scripts/smoke-model-selection.ts",
    "smoke:bridge-message": "node --experimental-strip-types scripts/smoke-bridge-message-utils.ts"
  },
  "files": [
    "docs",
    "extensions",
    "vendor",
    "scripts",
    "prompts",
    "skills",
    "agents",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "pi-interactive-subagents": "github:HazAT/pi-interactive-subagents"
  },
  "bundledDependencies": [
    "pi-interactive-subagents"
  ],
  "bundleDependencies": [
    "pi-interactive-subagents"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/register-ticket-agents.ts",
      "./extensions/interactive-subagents-tools.ts",
      "./extensions/interactive-session-artifacts.ts",
      "./extensions/ticket-flow-tools.ts",
      "./extensions/prompt-template-interactive-bridge.ts",
      "./vendor/pi-prompt-template-model/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
